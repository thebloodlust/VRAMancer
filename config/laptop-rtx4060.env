# VRAMancer Swarm — Laptop Worker (RTX 4060)
# GPU: RTX 4060 (8 GB, Ada Lovelace)
# Role: Worker node (joins the Proxmox server swarm)

VRM_NODE_ROLE=worker
VRM_API_PORT=5032

# Master IP — set this to your Proxmox server's LAN IP
VRM_CLUSTER_MASTER_IP=192.168.1.100

# GPU Configuration
VRM_CUDA_DEVICES=0
VRM_MEMORY_TIER_L1=cuda:0

# VRAM budget (MB) — RTX 4060 = ~7000 MB usable
VRM_MAX_MEMORY_MB=7000

# Network
VRM_AITP_PORT=9109
VRM_AITP_SENSING_PORT=9110
VRM_CLUSTER_SECRET=CHANGE_ME_IN_PRODUCTION

# NVMe cache
VRM_NVME_CACHE_DIR=/tmp/vramancer/cache
VRM_NVME_CACHE_MB=10000

# XDP mode
VRM_XDP_MODE=auto

# Power profile — laptop, respect thermals
VRM_POWER_PROFILE=standard

# Security (same token as master)
VRM_API_TOKEN=CHANGE_ME
VRM_PRODUCTION=0
