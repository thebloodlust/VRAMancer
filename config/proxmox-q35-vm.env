# VRAMancer Swarm — Proxmox Q35 VM (GPU Passthrough)
# Host: Standard PC (Q35 + ICH9, 2009) — QEMU/KVM
# GPUs: RTX 5070 Ti (16 GB, Blackwell) + RTX 3090 (24 GB, Ampere)
# Driver: 590.48.01, CUDA 13.1
# Role: Master node (runs the API + orchestration)

VRM_NODE_ROLE=master
VRM_CLUSTER_MASTER=true
VRM_API_PORT=5030

# ── GPU Configuration ──
# Both GPUs are PCI-passthrough'd into the VM
# GPU 0: RTX 5070 Ti — 16303 MiB (Blackwell, PCIe 5.0, 94.6 FP16 TFLOPS)
# GPU 1: RTX 3090    — 24576 MiB (Ampere, PCIe 4.0, 71.0 FP16 TFLOPS)
VRM_CUDA_DEVICES=0,1
VRM_NUM_GPUS=2
VRM_MEMORY_TIER_L1=cuda:0
VRM_MEMORY_TIER_L2=cuda:1

# VRAM budget (MB) — conservative for VM overhead
# GPU 0: ~14500 MB usable (16303 - Xorg - VM overhead)
# GPU 1: ~22500 MB usable (24576 - Xorg - VM overhead)
VRM_MAX_MEMORY_MB=37000

# ── VM-Specific: IOMMU / ACS / P2P ──
# In Q35 VMs, vfio-pci presents GPUs with separate IOMMU groups.
# P2P between Blackwell + Ampere across virtual PCIe root ports is
# typically BLOCKED by the hypervisor and NVIDIA driver.
# Force CPU-staged transfers (pinned memory, reliable ~25 GB/s).
VRM_TRANSFER_METHOD=cpu_staged
VRM_TRANSFER_P2P=false

# If you pass ACS overrides on the host (unsafe_interrupts=1), 
# set these to enable P2P probing:
# VRM_TRANSFER_P2P=true
# VRM_TRANSFER_METHOD=auto

# ── Heterogeneous Split Strategy ──
# "balanced" = VRAM * sqrt(compute_efficiency)
#   GPU 0 (5070 Ti): faster compute, fewer layers → ~42% of model
#   GPU 1 (3090):    more VRAM, more layers      → ~58% of model
VRM_HETERO_STRATEGY=balanced

# ── NVMe cache for L5 tier ──
VRM_NVME_CACHE_DIR=/var/lib/vramancer/cache
VRM_NVME_CACHE_MB=50000

# ── Network ──
VRM_FASTPATH_IF=eno1
VRM_AITP_PORT=9109
VRM_AITP_SENSING_PORT=9110
VRM_CLUSTER_SECRET=CHANGE_ME_IN_PRODUCTION

# XDP: auto-detect AF_XDP, fall back to raw/udp
VRM_XDP_MODE=auto

# ── Power / Performance ──
VRM_POWER_PROFILE=high_perf

# ── Model defaults ──
# With ~37 GB usable VRAM, fits 70B Q4 or 13B FP16 easily
VRM_DEFAULT_MODEL=meta-llama/Llama-2-13b-hf
VRM_DEFAULT_DTYPE=float16

# ── Security ──
VRM_API_TOKEN=CHANGE_ME
VRM_PRODUCTION=0

# ── Observability ──
VRM_LOG_LEVEL=INFO
VRM_METRICS_ENABLED=true
VRM_METRICS_PORT=9108
