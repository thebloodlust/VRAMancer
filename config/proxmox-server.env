# VRAMancer Swarm — Proxmox Server (Ubuntu)
# GPUs: RTX 5070 Ti (16 GB, Blackwell) + RTX 3090 (24 GB, Ampere)
# Role: Master node (runs the API + orchestration)

VRM_NODE_ROLE=master
VRM_CLUSTER_MASTER=true
VRM_API_PORT=5030

# GPU Configuration (auto-detected, but explicit for multi-GPU)
VRM_CUDA_DEVICES=0,1
VRM_MEMORY_TIER_L1=cuda:0
VRM_MEMORY_TIER_L2=cuda:1

# VRAM budget (MB) — conservative to leave headroom
# GPU 0: RTX 5070 Ti = ~14500 MB usable
# GPU 1: RTX 3090   = ~22000 MB usable
VRM_MAX_MEMORY_MB=36500

# Network — AITP fast path
VRM_FASTPATH_IF=eno1
VRM_AITP_PORT=9109
VRM_AITP_SENSING_PORT=9110
VRM_CLUSTER_SECRET=CHANGE_ME_IN_PRODUCTION

# NVMe cache for L5 tier (fast model shard spilling)
VRM_NVME_CACHE_DIR=/var/lib/vramancer/cache
VRM_NVME_CACHE_MB=50000

# XDP mode: auto-detect AF_XDP, fall back to raw/udp
VRM_XDP_MODE=auto

# Transfer manager: enable P2P between GPUs 0-1
VRM_TRANSFER_P2P=true

# Power profile
VRM_POWER_PROFILE=high_perf

# Security
VRM_API_TOKEN=CHANGE_ME
VRM_PRODUCTION=0
